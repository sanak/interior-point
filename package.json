{
  "name": "@interior-point/monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "simple-git-hooks",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "format": "prettier --write \"**/*.{ts,mts,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,mts,json,md,yml,yaml}\"",
    "build:js": "pnpm --filter interior-point run build",
    "test:js": "pnpm --filter interior-point run test",
    "test:rs": "cd rs && cargo test",
    "test": "pnpm test:js && pnpm test:rs",
    "bench:js": "pnpm --filter interior-point exec vitest bench",
    "bench:rs": "cd rs && cargo bench",
    "bench": "pnpm bench:js && pnpm bench:rs",
    "docs:dev": "pnpm --filter @interior-point/docs run dev",
    "docs:build": "pnpm --filter @interior-point/docs run build",
    "docs:preview": "pnpm --filter @interior-point/docs run preview"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged"
  },
  "lint-staged": {
    "*.{ts,tsx,mts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ],
    "*.rs": [
      "rustfmt"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.0",
    "typescript-eslint": "^8.20.0",
    "prettier": "^3.4.0",
    "simple-git-hooks": "^2.11.0",
    "lint-staged": "^15.4.0",
    "typescript": "^5.7.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "simple-git-hooks"
    ]
  }
}
